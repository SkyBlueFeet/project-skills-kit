{
  "name": "@skybluefeet/skills-kit",
  "version": "0.3.0",
  "description": "Project rules starter kit for Codex/Claude repositories",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SkyBlueFeet/project-skills-kit.git"
  },
  "bugs": {
    "url": "https://github.com/SkyBlueFeet/project-skills-kit/issues"
  },
  "homepage": "https://github.com/SkyBlueFeet/project-skills-kit#readme",
  "bin": {
    "skills-kit": "./src/cli.js"
  },
  "files": [
    "src",
    "templates",
    "README.md"
  ],
  "scripts": {
    "start": "node ./src/cli.js",
    "check": "npm run check:syntax && npm run check:cli",
    "check:syntax": "node --check ./src/cli.js",
    "check:cli": "node ./src/cli.js --help",
    "pack:check": "npm pack --dry-run --cache ./.npm-cache",
    "prepublishOnly": "npm run check && npm run pack:check"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "keywords": [
    "codex",
    "claude",
    "agent",
    "rules",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.5.0"
  }
}
